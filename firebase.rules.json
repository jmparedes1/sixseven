{
  "rules": {
    ".read": false,
    ".write": false,
    "events": {
      "$code": {
        ".read": "auth != null && $code.matches(/^[A-Z0-9]{10}$/)",
        ".write": "auth != null && $code.matches(/^[A-Z0-9]{10}$/) && ((!data.exists() && newData.child('creatorUid').val() == auth.uid) || data.child('creatorUid').val() == auth.uid || root.child('adminSessions').child($code).child(auth.uid).child('active').val() == true)",
        ".validate": "!newData.exists() || newData.hasChildren(['name','reason','creatorUid','status','createdAt','expiresAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "reason": {
          ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 40"
        },
        "theme": {
          ".validate": "newData.isString() && newData.val().matches(/^(dark|passion|white|night|gold)$/)"
        },
        "creatorUid": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.val() == 'open' || newData.val() == 'closed'"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "roundStartedAt": {
          ".validate": "newData.isNumber()"
        },
        "expiresAt": {
          ".validate": "newData.isNumber()"
        },
        "roundDurationMs": {
          ".validate": "newData.val() == 420000"
        },
        "totalRounds": {
          ".validate": "newData.val() == 6"
        },
        "maxParticipants": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        },
        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid && root.child('events').child($code).child('status').val() == 'open' && root.child('events').child($code).child('expiresAt').val() > now",
            ".validate": "!newData.exists() || (newData.hasChildren(['name','normalizedName','consentAcceptedAt']) && newData.child('name').isString() && newData.child('name').val().length > 0 && newData.child('name').val().length <= 40 && newData.child('normalizedName').isString() && newData.child('consentAcceptedAt').isNumber())"
          }
        },
        "nameIndex": {
          "$name": {
            ".write": "auth != null && ((!data.exists() && newData.val() == auth.uid) || data.val() == auth.uid || !newData.exists())",
            ".validate": "!newData.exists() || (newData.isString() && newData.val() == auth.uid)"
          }
        },
        "votesByRound": {
          "$round": {
            "$uid": {
              ".write": "auth != null && auth.uid == $uid && root.child('events').child($code).child('status').val() == 'open' && root.child('events').child($code).child('expiresAt').val() > now && !data.exists()",
              ".validate": "newData.hasChildren(['targetUid','createdAt']) && newData.child('targetUid').isString() && newData.child('targetUid').val() != auth.uid && root.child('events').child($code).child('participants').child(newData.child('targetUid').val()).exists() && newData.child('createdAt').isNumber()"
            }
          }
        },
        "$other": {
          ".validate": true
        }
      }
    },
    "eventSecrets": {
      "$code": {
        ".read": false,
        ".write": "auth != null && $code.matches(/^[A-Z0-9]{10}$/) && ((!data.exists() && root.child('events').child($code).child('creatorUid').val() == auth.uid) || root.child('events').child($code).child('creatorUid').val() == auth.uid || root.child('adminSessions').child($code).child(auth.uid).child('active').val() == true)",
        ".validate": "!newData.exists() || (newData.child('creatorKey').isString() && newData.child('creatorKey').val().matches(/^[A-Z0-9-]{6,32}$/))"
      }
    },
    "adminSessions": {
      "$code": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid && $code.matches(/^[A-Z0-9]{10}$/) && (root.child('events').child($code).child('creatorUid').val() == auth.uid || newData.child('key').val() == root.child('eventSecrets').child($code).child('creatorKey').val())",
          ".validate": "!newData.exists() || (newData.hasChildren(['active','key','claimedAt']) && newData.child('active').isBoolean() && newData.child('key').isString() && newData.child('claimedAt').isNumber())"
        }
      }
    },
    "chats": {
      "$code": {
        "$match": {
          ".read": "auth != null && root.child('events').child($code).child('participants').child(auth.uid).exists()",
          "messages": {
            "$msg": {
              ".write": "auth != null && root.child('events').child($code).child('participants').child(auth.uid).exists() && newData.child('uid').val() == auth.uid",
              ".validate": "newData.hasChildren(['uid','name','text','createdAt']) && newData.child('uid').isString() && newData.child('name').isString() && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 240 && newData.child('createdAt').isNumber()"
            }
          }
        }
      }
    }
  }
}