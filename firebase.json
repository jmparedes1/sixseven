{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "firebase.rules.json",
      "README.md",
      "INSTRUCCIONES_SUBIDA.md",
      "INSTRUCCIONES_GITHUB_PAGES.md",
      "INSTRUCCIONES_FIREBASE_HOSTING.md",
      "CHECKLIST_PUBLICACION.md",
      "package.json"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|webp|jpg|jpeg)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "database": {
    "rules": "firebase.rules.json"
  }
}