{
  "rules": {
    "events": {
      "$code": {
        ".read": "auth != null && $code.matches(/^[A-Z0-9]{10}$/)",
        ".write": "auth != null && $code.matches(/^[A-Z0-9]{10}$/) && (!data.exists() || data.child('creatorUid').val() == auth.uid)",
        ".validate": "newData.hasChildren(['name', 'reason', 'creatorUid', 'status', 'expiresAt'])",
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80" },
        "reason": { ".validate": "newData.isString() && newData.val().matches(/^(7 minutos a solas|Un café|Una cena|Una noche)$/)" },
        "creatorUid": { ".validate": "newData.isString() && (!data.exists() ? newData.val() == auth.uid : newData.val() == data.child('creatorUid').val())" },
        "status": { ".validate": "newData.val() == 'waiting' || newData.val() == 'open' || newData.val() == 'closed'" },
        "expiresAt": { ".validate": "newData.isNumber() && newData.val() > now && newData.val() <= now + 604800000" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "maxParticipants": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "soundEnabled": { ".validate": "newData.isBoolean()" },
        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid && !data.exists() && (root.child('events').child($code).child('status').val() == 'waiting' || root.child('events').child($code).child('status').val() == 'open') && root.child('events').child($code).child('expiresAt').val() > now",
            ".validate": "newData.hasChildren(['name', 'normalizedName', 'consentAcceptedAt']) && newData.child('name').isString() && newData.child('name').val().length > 0 && newData.child('name').val().length <= 40 && newData.child('normalizedName').isString() && newData.child('normalizedName').val().length >= 2 && newData.child('normalizedName').val().length <= 48 && newData.child('consentAcceptedAt').isNumber()"
          }
        },
        "nameIndex": {
          "$normalizedName": {
            ".write": "auth != null && (!data.exists() || data.val() == auth.uid)",
            ".validate": "newData.isString() && newData.val() == auth.uid"
          }
        },
        "votes": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid && !data.exists() && root.child('events').child($code).child('status').val() == 'open' && root.child('events').child($code).child('expiresAt').val() > now",
            ".validate": "newData.hasChildren(['targetUid', 'createdAt']) && newData.child('targetUid').isString() && root.child('events').child($code).child('participants').child($uid).exists() && root.child('events').child($code).child('participants').child(newData.child('targetUid').val()).exists() && newData.child('targetUid').val() != $uid && newData.child('createdAt').isNumber()"
          }
        },
        "matchPairs": {
          "$pair": {
            ".read": "auth != null",
            ".write": false,
            ".validate": "newData.val() == true"
          }
        },
        "$other": { ".validate": false }
      }
    },
    "privateMatches": {
      "$code": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": false
        }
      }
    }
  }
}
